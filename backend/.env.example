PORT=4000

# Prisma: use the Supabase *transaction pooler* (port 6543, add ?pgbouncer=true) for runtime.
# See: https://supabase.com/docs/guides/database/connecting-to-postgres
# For local Docker Postgres (no pooler), set DATABASE_URL and DIRECT_URL to the same URI.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sms_mvp?schema=public

# Migrations use a direct (non-pooled) connection. On Supabase, use the *direct* connection string
# (port 5432 from Project Settings → Database). For local dev, match DATABASE_URL.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/sms_mvp?schema=public

JWT_SECRET=replace-with-strong-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AI_SERVICE_URL=http://localhost:8000
CORS_ORIGIN=http://localhost:3000
